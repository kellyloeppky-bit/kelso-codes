<section class="subscribe">
  <div class="section-label">Follow Along</div>
  <p>Get new entries straight to your inbox. No spam. Just a sales guy learning to build in public.</p>
  <form class="email-form" id="subscribeForm" action="https://formspree.io/f/xpqykndp" method="POST">
    <input type="email" name="email" id="emailInput" placeholder="your@email.com" autocomplete="email" required />
    <button type="submit" id="submitBtn">Follow Along</button>
  </form>
  <p class="subscribe-note">No pitch. No cadence. Just the journal.</p>
  <p class="success-msg" id="successMsg">You're in. More in two weeks or so.</p>
  <p class="error-msg" id="errorMsg">Something went wrong. Please try again.</p>
</section>
