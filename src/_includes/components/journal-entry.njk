{%- for post in collections.journal | reverse -%}
<section class="journal">
  <div class="section-label">Journal — Entry {{ ("00" + post.data.entryNumber).slice(-3) }}</div>

  <div class="post-meta">{{ post.data.dateDisplay }} &nbsp;/&nbsp; {{ post.data.subtitle }}</div>

  <h2 class="post-title">{{ post.data.title }}</h2>

  <div class="post-body">
    {{ post.templateContent | safe }}

    {%- if post.data.acknowledgments -%}
    <p style="color: var(--muted); font-size: 0.88rem;">{{ post.data.acknowledgments }}</p>
    {%- endif -%}

    {%- if post.data.tags and post.data.tags.length > 0 -%}
    <div class="tags">
      {%- for tag in post.data.tags -%}
      <span class="tag">{{ tag }}</span>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>
</section>

{% include "components/coming-soon.njk" %}

{% include "components/subscribe.njk" %}

{%- endfor -%}
